<!DOCTYPE html>
<html lang="fa" dir="rtl">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>نوین سرویس - تعمیر لوازم خانگی در تهران</title>
    <style>
        /* فونت فارسی */
        @font-face {
            font-family: 'Vazir';
            src: url('font/Vazir.woff2') format('woff2'),
                 url('font/Vazir.woff') format('woff');
            font-weight: normal;
            font-style: normal;
        }

        body {
            font-family: 'Vazir', sans-serif;
            margin: 0;
            padding: 0;
            color: #333;
            line-height: 1.6;
            background-color: #f4f4f4;
        }

        .container {
            max-width: 1100px;
            margin: auto;
            overflow: hidden;
            padding: 0 20px;
        }

        /* Header Styles */
        header {
            background: #35424a;
            color: #ffffff;
            padding-top: 30px;
            min-height: 70px;
            border-bottom: #e8491d 3px solid;
        }

        header a {
            color: #ffffff;
            text-decoration: none;
            text-transform: uppercase;
            font-size: 16px;
        }

        header ul {
            margin: 0;
            padding: 0;
            list-style: none;
            display: flex; /* Use flexbox for horizontal navigation */
            align-items: center; /* Vertically align items */
        }

        header li {
            padding: 0 20px 0 20px;
        }

        header #branding {
            float: left;
        }

        header #branding h1 {
            margin: 0;
            font-size: 24px;
            color: #e8491d; /* Brand color for emphasis */
        }

        header nav {
            float: right;
            margin-top: 10px;
        }

        header .highlight {
            color: #e8491d;
            font-weight: bold;
        }

        /* Hero Section */
        #hero {
            min-height: 400px;
            background: url('./images/hero-bg.jpg') no-repeat center center/cover; /* Background image */
            text-align: center;
            color: #ffffff;
            display: flex;
            flex-direction: column;
            justify-content: center;
            align-items: center;
        }

        #hero h1 {
            margin-top: 0;
            font-size: 55px;
            margin-bottom: 10px;
            text-shadow: 2px 2px 5px rgba(0,0,0,0.5); /* Text shadow for readability */
        }

        #hero p {
            font-size: 20px;
            margin-bottom: 20px;
            text-shadow: 1px 1px 3px rgba(0,0,0,0.5); /* Text shadow for readability */
        }

        #hero .action-buttons {
            margin-top: 20px;
        }

        #hero .btn {
            display: inline-block;
            background: #e8491d;
            color: #ffffff;
            padding: 10px 20px;
            border: none;
            border-radius: 5px;
            font-size: 18px;
            cursor: pointer;
            text-decoration: none;
            transition: background-color 0.3s ease;
            margin: 5px;
        }

        #hero .btn:hover {
            background: #35424a;
            color: #ffffff;
        }

        /* Main Content Sections */
        section {
            padding: 60px 0;
            text-align: center;
        }

        section h2 {
            font-size: 36px;
            margin-bottom: 30px;
            color: #35424a;
        }

        /* Services Section */
        #services .service-item {
            display: inline-block;
            width: 30%;
            margin: 1.5%;
            padding: 20px;
            background: #ffffff;
            border: 1px solid #ddd;
            border-radius: 8px;
            box-shadow: 0 2px 5px rgba(0,0,0,0.1);
            transition: transform 0.3s ease, box-shadow 0.3s ease;
            vertical-align: top; /* Align items to the top */
        }

        #services .service-item:hover {
            transform: translateY(-5px);
            box-shadow: 0 8px 15px rgba(0,0,0,0.2);
        }

        #services .service-item i {
            font-size: 40px;
            color: #e8491d;
            margin-bottom: 15px;
        }

        #services .service-item h3 {
            margin-top: 0;
            font-size: 22px;
            color: #35424a;
            margin-bottom: 10px;
        }

        #services .service-item p {
            font-size: 16px;
            color: #555;
        }

        /* Contact Section */
        #contact {
            background: #e8f2f8; /* Light blue background */
            padding-top: 60px;
            padding-bottom: 60px;
        }

        #contact .contact-wrapper {
            display: flex;
            justify-content: space-between;
            gap: 30px;
            align-items: flex-start; /* Align items to the top */
        }

        #contact .contact-info,
        #contact .contact-map {
            flex: 1; /* Each takes half the space */
        }

        #contact h2 {
            color: #35424a;
        }

        #contact .contact-info ul {
            list-style: none;
            padding: 0;
            text-align: right; /* Align text to the right */
        }

        #contact .contact-info li {
            margin-bottom: 20px;
            font-size: 18px;
            color: #333;
            display: flex; /* Use flex for alignment */
            align-items: center; /* Vertically align icon and text */
            justify-content: flex-end; /* Push content to the right */
        }

        #contact .contact-info li i {
            margin-left: 15px; /* Space between icon and text */
            color: #e8491d;
            font-size: 24px;
        }

        #contact .contact-map iframe {
            width: 100%;
            height: 350px; /* Fixed height for the map */
            border: 0;
            border-radius: 8px;
            box-shadow: 0 2px 5px rgba(0,0,0,0.1);
        }

        /* Request Form Section */
        #request-form form {
            background: #ffffff;
            padding: 30px;
            border-radius: 8px;
            box-shadow: 0 4px 15px rgba(0,0,0,0.1);
            max-width: 700px;
            margin: 30px auto;
            text-align: right; /* Align form elements to the right */
        }

        #request-form .contact-row {
            display: flex;
            justify-content: space-between; /* Space out the inputs */
            margin-bottom: 15px;
            gap: 15px; /* Space between input groups */
        }

        #request-form .contact-row div {
            flex: 1; /* Each div takes equal space */
            width: 100%; /* Ensure full width within its flex container */
        }

        #request-form label {
            display: block;
            margin-bottom: 8px;
            font-weight: bold;
            color: #35424a;
        }

        #request-form input[type="text"],
        #request-form input[type="tel"],
        #request-form textarea {
            width: 100%; /* Full width */
            padding: 12px;
            border: 1px solid #ccc;
            border-radius: 5px;
            box-sizing: border-box; /* Include padding and border in element's total width and height */
            font-family: 'Vazir', sans-serif; /* Ensure Persian font */
            font-size: 16px;
        }

        #request-form textarea {
            resize: vertical; /* Allow vertical resizing */
        }

        #request-form .form-actions {
            text-align: center;
            margin-top: 30px;
        }

        #request-form .btn {
            display: inline-block;
            background: #e8491d;
            color: #ffffff;
            padding: 12px 25px;
            border: none;
            border-radius: 5px;
            font-size: 18px;
            cursor: pointer;
            text-decoration: none;
            transition: background-color 0.3s ease;
        }

        #request-form .btn:hover {
            background: #35424a;
        }

        #request-form .note {
            font-size: 14px;
            color: #666;
            margin-top: 15px;
        }

        #request-form .note a {
            color: #e8491d;
            font-weight: bold;
            text-decoration: none;
        }

        /* Footer Styles */
        footer {
            background: #35424a;
            color: #ffffff;
            text-align: center;
            padding: 20px 0;
            margin-top: 30px;
        }

        footer p {
            margin: 0;
            font-size: 14px;
        }

        footer a {
            color: #e8491d;
            text-decoration: none;
        }

        /* Responsive Design */
        @media(max-width: 768px) {
            header nav,
            header #branding {
                float: none;
                text-align: center;
                width: 100%;
            }

            header nav ul {
                display: block; /* Stack navigation items */
                margin-top: 10px;
            }

            header li {
                padding: 10px 0;
            }

            #hero h1 {
                font-size: 40px;
            }

            #hero p {
                font-size: 18px;
            }

            #services .service-item {
                width: 90%;
                margin-bottom: 20px;
            }

            #contact .contact-wrapper {
                flex-direction: column; /* Stack items vertically */
                text-align: center;
            }

            #contact .contact-info ul {
                justify-content: center; /* Center align items */
            }

            #contact .contact-info li {
                justify-content: center;
            }

            #contact .contact-info li i {
                margin-left: 10px;
            }

            #request-form .contact-row {
                flex-direction: column; /* Stack input groups */
            }

            #request-form .contact-row div {
                margin-bottom: 15px; /* Add space between stacked input groups */
            }
        }

        /* Font Awesome Integration (for icons) */
        /* You'll need to link to Font Awesome CSS in your HTML <head> */
        /* Example: <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.0.0/css/all.min.css"> */
        /* I've used placeholder class names for icons, replace with actual Font Awesome classes */
        .fa-solid.fa-phone::before { content: "\f095"; } /* Example for phone icon */
        .fa-solid.fa-envelope::before { content: "\f003"; } /* Example for email icon */
        .fa-solid.fa-location-dot::before { content: "\f3c5"; } /* Example for location icon */
        .fa-solid.fa-gear::before { content: "\f013"; } /* Example for service gear */
        .fa-solid.fa-certificate::before { content: "\f0a3"; } /* Example for services */
        .fa-solid.fa-handshake::before { content: "\f2b5"; } /* Example for consultation */

    </style>
    <!-- Link Font Awesome CSS here -->
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.0.0/css/all.min.css">
</head>
<body>
    <header>
        <div class="container">
            <div id="branding">
                <h1><span class="highlight">نوین</span> سرویس</h1>
            </div>
            <nav>
                <ul>
                    <li><a href="#services">خدمات</a></li>
                    <li><a href="#contact">تماس با ما</a></li>
                    <li><a href="#request-form" class="btn-nav">درخواست تعمیر</a></li>
                </ul>
            </nav>
        </div>
    </header>

    <section id="hero">
        <div class="container">
            <h1>تعمیر تخصصی لوازم خانگی در تهران</h1>
            <p>با اطمینان، لوازم خانگی خود را به ما بسپارید.</p>
            <div class="action-buttons">
                <a href="tel:0912062923" class="btn"><i class="fas fa-phone"></i> تماس فوری</a>
                <a href="#request-form" class="btn"><i class="fas fa-gear"></i> ثبت درخواست تعمیر</a>
            </div>
            <div style="margin-top: 30px;">
                <p><i class="fas fa-location-dot"></i> آدرس: تهران، میدان ونک، خیابان ونک</p>
                <p><i class="fas fa-envelope"></i> ایمیل: info@karami24.com</p>
            </div>
        </div>
    </section>

    <section id="services">
        <div class="container">
            <h2>خدمات ما</h2>
            <div class="service-item">
                <i class="fas fa-snowflake"></i> <!-- Placeholder for Fridge Icon -->
                <h3>تعمیر یخچال</h3>
                <p>عیب‌یابی و رفع تخصصی انواع یخچال‌های خانگی و صنعتی.</p>
            </div>
            <div class="service-item">
                <i class="fas fa-wind"></i> <!-- Placeholder for Washing Machine Icon -->
                <h3>تعمیر ماشین لباسشویی</h3>
                <p>تعمیرات صفر تا صد ماشین‌های لباسشویی اتوماتیک و نیمه اتوماتیک.</p>
            </div>
            <div class="service-item">
                <i class="fas fa-wine-glass"></i> <!-- Placeholder for Side-by-Side Fridge Icon -->
                <h3>تعمیر ساید بای ساید</h3>
                <p>تخصص در تعمیر و سرویس ساید بای ساید با قطعات اصلی.</p>
            </div>
            <div class="service-item">
                <i class="fas fa-utensils"></i> <!-- Placeholder for Dishwasher Icon -->
                <h3>تعمیر ظرفشویی</h3>
                <p>رفع مشکلات انواع ماشین‌های ظرفشویی رومیزی و توکار.</p>
            </div>
            <div class="service-item">
                <i class="fas fa-fire"></i> <!-- Placeholder for Stove Icon -->
                <h3>تعمیر اجاق گاز</h3>
                <p>تعمیرات تخصصی اجاق گازهای فردار، رومیزی و شومینه‌ای.</p>
            </div>
            <div class="service-item">
                <i class="fas fa-handshake"></i> <!-- Placeholder for Consultation Icon -->
                <h3>مشاوره قبل از اعزام</h3>
                <p>راهنمایی و مشاوره تلفنی رایگان برای تشخیص اولیه مشکل.</p>
            </div>
        </div>
    </section>

    <section id="contact">
        <div class="container">
            <h2>تماس با ما</h2>
            <div class="contact-wrapper">
                <div class="contact-info">
                    <ul>
                        <li><i class="fas fa-location-dot"></i> <strong>آدرس:</strong> تهران، میدان ونک، خیابان ونک، کوچه فرهاد جنب هتل آپارتمان النور</li>
                        <li><i class="fas fa-phone"></i> <strong>تلفن:</strong> <a href="tel:0912062923">۰۹۱۲۰۶۲۹۲۳</a></li>
                        <li><i class="fas fa-envelope"></i> <strong>ایمیل:</strong> <a href="mailto:info@karami24.com">info@karami24.com</a></li>
                    </ul>
                </div>
                <div class="contact-map">
                    <iframe src="https://www.google.com/maps/embed?pb=!1m14!1m12!1m3!1d12610.210237790893!2d51.41103935!3d35.7702483!2m3!1f0!2f0!3f0!3m2!1i1024!2i768!4f13.1!5e0!3m2!1sen!2s!4v1719910000000!5m2!1sen!2s" width="600" height="450" style="border:0;" allowfullscreen="" loading="lazy" referrerpolicy="no-referrer-when-downgrade"></iframe>
                </div>
            </div>
        </div>
    </section>

    <section id="request-form">
        <div class="container">
            <h2>درخواست تعمیر</h2>
            <p>لطفاً فرم زیر را تکمیل کنید تا همکاران ما با شما تماس بگیرند.</p>
            <form id="requestForm">
                <div class="contact-row">
                    <div>
                        <label for="name">نام و نام خانوادگی</label>
                        <input id="name" name="name" type="text" placeholder="" required />
                    </div>
                    <div>
                        <label for="phone">شماره تماس</label>
                        <input id="phone" name="phone" type="tel" placeholder="مثلاً 09xxxxxxxxx" required />
                    </div>
                </div>

                <div class="contact-row">
                    <div>
                        <label for="device">نوع دستگاه</label>
                        <input id="device" name="device" type="text" placeholder="یخچال / لباسشویی / ساید / ظرفشویی / اجاق گاز" required />
                    </div>
                    <div>
                        <label for="area">محله (تهران)</label>
                        <input id="area" name="area" type="text" placeholder="" required />
                    </div>
                </div>

                <div>
                    <label for="problem">شرح مشکل</label>
                    <textarea id="problem" name="problem" rows="5" placeholder="توضیحات"></textarea>
                </div>

                <div class="form-actions">
                    <button class="btn btn-primary" type="submit">ارسال درخواست به روبیکا</button>
                    <p class="note">
                        یا مستقیم تماس بگیرید: <a href="tel:0912062923">۰۹۱۲۰۶۲۹۲۳</a>
                    </p>
                </div>
            </form>
        </div>
    </section>

    <footer>
        <div class="container">
            <p>کپی‌رایت &copy; <script>document.write(new Date().getFullYear());</script> نوین سرویس. تمامی حقوق محفوظ است.</p>
            <p>طراحی شده با ❤️ آتی نما </p>
        </div>
    </footer>

    <script>
        // لینک روبیکای شما
        const RUBIKA_LINK = "https://rubika.ir/safaiias";

        // Smooth scrolling for navigation links
        document.querySelectorAll('a[href^="#"]').forEach(anchor => {
            anchor.addEventListener('click', function (e) {
                e.preventDefault();
                document.querySelector(this.getAttribute('href')).scrollIntoView({
                    behavior: 'smooth'
                });
            });
        });

        // Form submission handler
        document.getElementById("requestForm").addEventListener("submit", function(e){
            e.preventDefault();

            const name = document.getElementById("name").value.trim();
            const phone = document.getElementById("phone").value.trim();
            const device = document.getElementById("device").value.trim();
            const area = document.getElementById("area").value.trim();
            const problem = document.getElementById("problem").value.trim();

            // ساخت متن پیام برای روبیکا
            const message =
                `سلام نوین سرویس 👋\n\n` +
                `**اطلاعات درخواست کننده:**\n` +
                `نام: ${name}\n` +
                `تلفن: ${phone}\n` +
                `\n**جزئیات سرویس:**\n` +
                `دستگاه: ${device}\n` +
                `محله: ${area}\n` +
                `شرح مشکل: ${problem || "-"}\n`;

            // ساخت لینک نهایی برای روبیکا با اضافه کردن متن پیام
            const url = RUBIKA_LINK + "?text=" + encodeURIComponent(message);

            // هدایت کاربر به روبیکا
            window.location.href = url;
        });
    </script>
</body>
</html>
